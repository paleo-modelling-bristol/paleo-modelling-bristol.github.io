# Optional build-time configuration. Copy to `.env.local` for local builds.
# None of these are required for the default GitHub Pages deployment.

# Canonical site URL, used for <meta> tags / Open Graph.
# Defaults to https://paleo-modelling-bristol.github.io
# SITE_URL="https://paleo-modelling-bristol.github.io"

# Sub-path base, ONLY needed when hosting under a project page such as
# https://<user>.github.io/<repo>. Leave unset for the organisation site
# served at the domain root.
# BASE_PATH="/paleo-modelling-bristol.github.io"
